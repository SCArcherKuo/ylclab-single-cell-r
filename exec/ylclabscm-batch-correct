#!/usr/bin/env Rscript

library(optparse)
library(ylclabscm)
library(arrow)
library(Matrix)
library(Seurat)

option_list <- list(
  make_option("--parquet-path",      type="character", help="Input parquet file"),
  make_option("--row-path",          type="character", help="Input row feature names TSV"),
  make_option("--column-path",       type="character", help="Input column sample names TSV"),
  make_option("--method",            type="character", help="CCA | RPCA | JointPCA | FastMNN"),
  make_option("--batch-column",      type="character", help="Metadata column for batch"),
  make_option("--bio-color-label",   type="character", default="", help="Metadata column for bio groups"),
  make_option("--analysis-id",       type="integer",   help="analysisId (103 or 203)"),
  make_option("--serial-number",     type="character", help="Project serial number"),
  make_option("--dataset-uid",       type="integer",   help="Dataset UID"),
  make_option("--output-parquet",    type="character", help="Output corrected parquet path"),
  make_option("--output-row",        type="character", help="Output row TSV path"),
  make_option("--output-column",     type="character", help="Output column TSV path"),
  make_option("--metadata-path",     type="character", default="", help="Optional sample metadata parquet"),
  make_option("--output-sentinel",   type="character", default="batch_correction_metadata.json",
              help="Output sentinel JSON path")
)
opts <- NULL

tryCatch({
  opts <- parse_args(OptionParser(option_list = option_list))

  # 1. Load data — input parquet is sparse triplet (row, col, value) with 0-based indices.
  #    TSV files vary in schema: row TSV may have (mode, mass, index), column TSV (sample, index).
  #    Use the `index` column to order; construct names from all other columns.
  sparse_df  <- arrow::read_parquet(opts$`parquet-path`)
  row_df     <- read.table(opts$`row-path`,    header=TRUE, sep="\t", stringsAsFactors=FALSE)
  column_df  <- read.table(opts$`column-path`, header=TRUE, sep="\t", stringsAsFactors=FALSE)
  row_df     <- row_df[order(row_df$index), ]
  column_df  <- column_df[order(column_df$index), ]

  make_names <- function(df) {
    name_cols <- setdiff(colnames(df), "index")
    if (length(name_cols) == 1) df[[name_cols]] else
      apply(df[, name_cols, drop = FALSE], 1, paste, collapse = "_")
  }
  row_names    <- make_names(row_df)
  column_names <- make_names(column_df)

  mat <- Matrix::sparseMatrix(
    i    = sparse_df$row + 1L,
    j    = sparse_df$col + 1L,
    x    = sparse_df$value,
    dims = c(length(row_names), length(column_names))
  )
  rownames(mat) <- row_names
  colnames(mat) <- column_names

  # 2. Load metadata if provided — support both parquet and CSV formats
  meta <- if (nchar(opts$`metadata-path`) > 0) {
    mp <- opts$`metadata-path`
    if (grepl("\\.csv$", mp, ignore.case = TRUE)) {
      read.csv(mp, stringsAsFactors = FALSE, row.names = NULL)
    } else {
      as.data.frame(arrow::read_parquet(mp))
    }
  } else {
    data.frame(row.names = column_names)
  }

  # 3. Build Seurat object (input is pre-normalized; populate data layer from counts so
  #    ScaleData can find it without re-running NormalizeData)
  obj <- CreateSeuratObject(counts = mat, meta.data = meta)
  obj <- SetAssayData(obj, layer = "data", new.data = GetAssayData(obj, layer = "counts"))
  obj <- FindVariableFeatures(obj, verbose = FALSE)
  obj <- ScaleData(obj, verbose = FALSE)
  # Cap npcs by (min batch size - 1) so FindIntegrationAnchors never exceeds
  # the smallest batch. Fall back gracefully if batch column is absent.
  min_batch <- if (opts$`batch-column` %in% colnames(meta) && nrow(meta) > 0) {
    min(table(meta[[opts$`batch-column`]])) - 1L
  } else {
    Inf
  }
  npcs <- min(30L, nrow(mat) - 1L, ncol(mat) - 1L, min_batch)
  npcs <- max(1L, as.integer(npcs))
  obj <- RunPCA(obj, npcs = npcs, verbose = FALSE)

  # 4. PCA before correction
  pca_before <- compute_pca_coords(obj)

  # 5. Split layers by batch and integrate
  obj[["RNA"]] <- split(obj[["RNA"]], f = obj[[opts$`batch-column`]][,1])
  obj <- batch_correct_seurat(obj, method = opts$method, batch_column = opts$`batch-column`)

  # 6. Re-run PCA on corrected embedding
  obj <- RunPCA(obj, reduction.name = "pca_after", npcs = npcs, verbose = FALSE)
  pca_after <- compute_pca_coords(obj, reduction = "pca_after")

  # 7. Write outputs — output parquet must match input sparse triplet format
  corrected_dense  <- GetAssayData(obj, assay = "RNA", layer = "data")
  corrected_sparse <- Matrix::summary(Matrix::Matrix(corrected_dense, sparse = TRUE))
  corrected_df <- data.frame(
    row   = corrected_sparse$i - 1L,
    col   = corrected_sparse$j - 1L,
    value = corrected_sparse$x
  )
  arrow::write_parquet(corrected_df, opts$`output-parquet`)
  # Preserve original TSV schemas — features and cells do not change after batch correction
  write.table(row_df,    opts$`output-row`,    row.names = FALSE, col.names = TRUE, quote = FALSE, sep = "\t")
  write.table(column_df, opts$`output-column`, row.names = FALSE, col.names = TRUE, quote = FALSE, sep = "\t")

  # 8. Resolve labels
  batch_labels <- if (opts$`batch-column` %in% colnames(obj@meta.data))
    as.character(obj@meta.data[[opts$`batch-column`]]) else character(0)
  bio_labels <- if (nchar(opts$`bio-color-label`) > 0 &&
                    opts$`bio-color-label` %in% colnames(obj@meta.data))
    as.character(obj@meta.data[[opts$`bio-color-label`]]) else character(0)

  # 9. Write sentinel
  write_sentinel(list(
    serial_number              = opts$`serial-number`,
    dataset_uid                = opts$`dataset-uid`,
    pipeline_stage             = "analysis",
    analysis_id                = opts$`analysis-id`,
    storage_path               = normalizePath(opts$`output-parquet`, mustWork = FALSE),
    row_path                   = normalizePath(opts$`output-row`,     mustWork = FALSE),
    column_path                = normalizePath(opts$`output-column`,  mustWork = FALSE),
    pca_before                 = pca_before$points,
    pca_after                  = pca_after$points,
    pca_variance_ratio_before  = pca_before$variance_ratio,
    pca_variance_ratio_after   = pca_after$variance_ratio,
    batch_labels               = batch_labels,
    bio_labels                 = bio_labels,
    status                     = "completed"
  ), opts$`output-sentinel`)

  cat("Done.\n")

}, error = function(e) {
  sentinel_path <- if (!is.null(opts) && nchar(opts$`output-sentinel`) > 0)
    opts$`output-sentinel` else "batch_correction_metadata.json"
  write_sentinel(list(
    serial_number  = if (!is.null(opts)) opts$`serial-number`  else NA,
    dataset_uid    = if (!is.null(opts)) opts$`dataset-uid`    else NA,
    pipeline_stage = "analysis",
    analysis_id    = if (!is.null(opts)) opts$`analysis-id`    else NA,
    status         = "failed",
    error_message  = conditionMessage(e)
  ), sentinel_path)
  stop(e)
})

#!/usr/bin/env Rscript

library(optparse)
library(ylclabscm)
library(arrow)
library(Matrix)
library(Seurat)

option_list <- list(
  make_option("--parquet-path",         type="character", help="Input parquet file (sparse triplet)"),
  make_option("--row-path",             type="character", help="Input row feature names TSV"),
  make_option("--column-path",          type="character", help="Input column sample names TSV"),
  make_option("--metadata-path",        type="character", default="", help="Optional sample metadata CSV/parquet"),
  make_option("--cluster-labels-path",  type="character", default="", help="Cluster labels parquet from clustering step"),
  make_option("--method",               type="character", help="bimod|ROC|negbinom|poisson|LR|MAST|DESeq2"),
  make_option("--group-by",             type="character", default="cluster", help="Metadata or cluster column for grouping"),
  make_option("--reference",            type="character", default="rest", help="Reference group for comparison"),
  make_option("--n-top-features",       type="integer",   default=50L, help="Number of top features per group"),
  make_option("--chunk-size",           type="integer",   default=10000L, help="Features per processing chunk"),
  make_option("--output-parquet",       type="character", default="differential_abundance.parquet",
              help="Output results parquet path"),
  make_option("--output-row",           type="character", default="row_feature_names.tsv",
              help="Output row TSV path"),
  make_option("--output-column",        type="character", default="column_sample_names.tsv",
              help="Output column TSV path"),
  make_option("--analysis-id",          type="integer",   help="analysisId (107 or 204)"),
  make_option("--serial-number",        type="character", help="Project serial number"),
  make_option("--dataset-uid",          type="integer",   help="Dataset UID"),
  make_option("--output-sentinel",      type="character", default="differential_abundance_metadata.json",
              help="Output sentinel JSON path")
)
opts <- NULL

tryCatch({
  opts <- parse_args(OptionParser(option_list = option_list))

  # 1. Read feature and sample names directly (no full matrix load)
  read_name_list <- function(path) {
    first_line <- readLines(path, n = 1)
    if (grepl("\t", first_line)) {
      df <- read.table(path, header = TRUE, sep = "\t", stringsAsFactors = FALSE)
      if ("index" %in% colnames(df)) {
        df <- df[order(df$index), ]
        name_cols <- setdiff(colnames(df), "index")
        if (length(name_cols) == 1) return(df[[name_cols]])
        return(apply(df[, name_cols, drop = FALSE], 1, paste, collapse = "_"))
      }
    }
    readLines(path)
  }

  row_names    <- read_name_list(opts$`row-path`)
  column_names <- read_name_list(opts$`column-path`)

  # 2. Load metadata if provided
  meta <- if (nchar(opts$`metadata-path`) > 0) {
    mp <- opts$`metadata-path`
    if (grepl("\\.csv$", mp, ignore.case = TRUE)) {
      read.csv(mp, stringsAsFactors = FALSE, row.names = NULL)
    } else {
      as.data.frame(arrow::read_parquet(mp))
    }
  } else {
    data.frame(row.names = column_names)
  }

  # 3. Load cluster labels if provided
  cluster_labels <- NULL
  if (nchar(opts$`cluster-labels-path`) > 0) {
    cl_df <- as.data.frame(arrow::read_parquet(opts$`cluster-labels-path`))
    # Cluster parquet has columns: cell, cluster
    cluster_labels <- setNames(as.character(cl_df$cluster), as.character(cl_df$cell))
  }

  # 4. Resolve group labels (named character vector: sample -> group)
  group_by <- opts$`group-by`
  if (group_by == "cluster" && !is.null(cluster_labels)) {
    group_labels <- cluster_labels[column_names]
  } else if (group_by %in% colnames(meta)) {
    group_labels <- setNames(as.character(meta[[group_by]]), column_names)
  } else {
    stop(paste("group-by column not found:", group_by,
               "— available:", paste(colnames(meta), collapse = ", ")))
  }

  # Remove samples with NA group labels
  valid <- !is.na(group_labels)
  if (sum(!valid) > 0) {
    cat(sprintf("Removing %d samples with NA group labels\n", sum(!valid)))
    column_names <- column_names[valid]
    group_labels <- group_labels[valid]
  }

  # 5. Run chunked differential abundance
  da_result <- diff_abundance_chunked(
    parquet_path  = opts$`parquet-path`,
    row_names     = row_names,
    column_names  = column_names,
    group_labels  = group_labels,
    method        = opts$method,
    reference     = opts$reference,
    chunk_size    = opts$`chunk-size`
  )

  if (is.null(da_result$all_results) || nrow(da_result$all_results) == 0) {
    stop("Chunked DA returned no results — check that groups have enough cells")
  }

  # 6. Apply BH FDR and format results
  result <- adjust_and_format_results(
    groups      = da_result$groups,
    all_results = da_result$all_results,
    method      = opts$method
  )

  # 7. Write output parquet — all features with pval_adj
  out_df <- da_result$all_results
  out_df$pval_adj <- p.adjust(out_df$pval, method = "BH")
  arrow::write_parquet(out_df, opts$`output-parquet`)

  # Preserve original TSV schemas
  writeLines(row_names,    opts$`output-row`)
  writeLines(column_names, opts$`output-column`)

  # 8. Truncate results_by_group for metadata (full data is in parquet)
  metadata_top_n <- 200L
  truncated_results <- lapply(result$results_by_group, function(grp) {
    n_keep <- min(metadata_top_n, length(grp$names))
    list(
      names          = grp$names[seq_len(n_keep)],
      scores         = grp$scores[seq_len(n_keep)],
      logfoldchanges = grp$logfoldchanges[seq_len(n_keep)],
      pvals          = grp$pvals[seq_len(n_keep)],
      pvals_adj      = grp$pvals_adj[seq_len(n_keep)]
    )
  })

  # 9. Write sentinel
  write_sentinel(list(
    serial_number    = opts$`serial-number`,
    dataset_uid      = opts$`dataset-uid`,
    pipeline_stage   = "analysis",
    analysis_id      = opts$`analysis-id`,
    storage_path     = normalizePath(opts$`output-parquet`, mustWork = FALSE),
    row_path         = normalizePath(opts$`output-row`,     mustWork = FALSE),
    column_path      = normalizePath(opts$`output-column`,  mustWork = FALSE),
    status           = "completed",
    test_method      = opts$method,
    group_by         = group_by,
    reference        = opts$reference,
    groups           = result$groups,
    results_by_group = truncated_results,
    n_top_features   = opts$`n-top-features`
  ), opts$`output-sentinel`)

  cat("Done.\n")

}, error = function(e) {
  sentinel_path <- if (!is.null(opts) && nchar(opts$`output-sentinel`) > 0)
    opts$`output-sentinel` else "differential_abundance_metadata.json"
  write_sentinel(list(
    serial_number  = if (!is.null(opts)) opts$`serial-number`  else NA,
    dataset_uid    = if (!is.null(opts)) opts$`dataset-uid`    else NA,
    pipeline_stage = "analysis",
    analysis_id    = if (!is.null(opts)) opts$`analysis-id`    else NA,
    status         = "failed",
    error_message  = conditionMessage(e)
  ), sentinel_path)
  stop(e)
})
